# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.qr6eswy.mongodb.net/interviq?retryWrites=true&w=majority
# Or local connection: mongodb://localhost:27017/ai-interview-agent

# JWT
JWT_SECRET=your_jwt_secret_hex_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_hex_string
JWT_REFRESH_EXPIRES_IN=30d

# Groq API
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Brevo HTTP Email API (Optional: bypasses SMTP port blocks on hosting platforms)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (for CORS + fallback email links)
FRONTEND_URL=http://localhost:5000

# Email SMTP Fallback (use Gmail or Mailtrap)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password